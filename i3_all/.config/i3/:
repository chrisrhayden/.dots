import json
import subprocess

def run_cmd(cmd):
    output = subprocess.run(cmd, stdout=subprocess.PIPE)

    if output:
        return output

    return False

def main():
    tree = run_cmd(['i3-msg', '-t', 'get_workspaces'])

    if not tree:
        print('bad tree')
        return

    tree = json.loads(tree.stdout)

    for monitor in tree:
        print('>>>>>>>>>', '<<<<<<<>\n')


if __name__ == '__main__':
    main()
